generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PermissionModule {
  USERS
  SEASONS
  TEAMS
  PEOPLE
  EVENTS
  FIXTURES
  WOCHENPLAN
  NEWS
  WEBSITE
  INFOBOARD
  FUNCTIONS
}

enum TeamCategory {
  KINDERFUSSBALL
  JUNIOREN
  AKTIVE
  FRAUEN
  SENIOREN
  TRAININGSGRUPPE
}

enum TeamSeasonStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PlayerSquadStatus {
  ACTIVE
  INACTIVE
  INJURED
  ABSENT
  ARCHIVED
}

enum TrainerTeamStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum TrainerQualificationType {
  DIPLOMA
  CERTIFICATE
  COURSE
  WORKSHOP
  FIRST_AID
  OTHER
}

enum TrainerQualificationStatus {
  VALID
  IN_PROGRESS
  EXPIRED
  PLANNED
  UNKNOWN
}
enum EventType {
  MATCH
  TOURNAMENT
  TRAINING
  OTHER
  VACATION_PERIOD
}

enum EventSource {
  CLUBCORNER_FVNWS
  MANUAL
  CSV_EXCEL_IMPORT
  MUNICIPALITY_API
}

enum EventStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
  ARCHIVED
}

enum PlanningResourceType {
  PITCH
  DRESSING_ROOM
  HALL
  OTHER
}

enum PlanningAllocationMode {
  HALF_PITCH
  FULL_PITCH
  MULTI_PITCH
  SINGLE_ROOM
  MULTI_ROOM
  FLEXIBLE
}

enum EventImportRunStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

enum ReviewWorkflowStage {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PUBLISHED
}

enum WorkflowDomain {
  EVENTS
  SEASONS
  TEAMS
  PEOPLE
  USERS
  IMPORTS
  WEBSITE
  NEWS
  INFOBOARD
  WOCHENPLAN
  FIXTURES
  FUNCTIONS
  SESSION_SECURITY
}

enum WorkflowAction {
  CREATE
  UPDATE
  DELETE
  REVIEW
  APPROVE
  REJECT
  PUBLISH
  IMPORT
}

enum UserAccessState {
  PENDING_INVITE
  INVITED
  ACTIVE
  SUSPENDED
}

enum UserTokenType {
  INVITE
  PASSWORD_RESET
}

enum VereinsleitungMeetingMode {
  ON_SITE
  ONLINE
  HYBRID
}

enum VereinsleitungMeetingProvider {
  NONE
  EXTERNAL
  MICROSOFT_TEAMS
}

enum VereinsleitungTeamsSyncStatus {
  NOT_CONFIGURED
  MANUAL
  PENDING
  CREATED
  FAILED
}

enum VereinsleitungMeetingParticipantStatus {
  INVITED
  CONFIRMED
  EXCUSED
  ABSENT
}

enum VereinsleitungMeetingDecisionType {
  DECISION
  TASK
  APPROVAL
  INFO
}

enum VereinsleitungMeetingApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum VereinsleitungInitiativeStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

enum VereinsleitungInitiativeWorkItemStatus {
  BACKLOG
  IN_PROGRESS
  RESOLVED
}

enum VereinsleitungInitiativeWorkItemAssigneeMode {
  NONE
  PERSON
  EXTERNAL
}

model OrganigrammDepartment {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  accentFrom  String   @default("#0b4aa2")
  accentVia   String   @default("#6a5acd")
  accentTo    String   @default("#d62839")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles Role[]

  @@index([sortOrder])
  @@index([isActive])
  @@index([name])
}

model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  passwordHash        String
  firstName           String
  lastName            String
  personId            String?         @unique
  isActive            Boolean         @default(true)
  accessState         UserAccessState @default(PENDING_INVITE)
  invitedAt           DateTime?
  inviteAcceptedAt    DateTime?
  passwordSetAt       DateTime?
  passwordResetSentAt DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  person     Person?     @relation(fields: [personId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  userRoles  UserRole[]
  auditLogs  AuditLog[]  @relation("AuditActor")
  userTokens UserToken[]

  @@index([isActive])
  @@index([accessState])
  @@index([personId])
}

model UserToken {
  id              String        @id @default(cuid())
  userId          String
  type            UserTokenType
  tokenHash       String        @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  createdByUserId String?
  metadataJson    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@index([consumedAt])
}

model Role {
  id                              String   @id @default(cuid())
  key                             String   @unique
  name                            String
  description                     String?
  canAccessVereinsleitung         Boolean  @default(false)
  canAttendVereinsleitungMeetings Boolean  @default(false)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
  organigrammDepartmentId         String?
  organigrammDisplayName          String?
  organigrammDescription          String?
  organigrammSortOrder            Int      @default(0)
  organigrammIsGroupRole          Boolean  @default(false)

  userRoles                 UserRole[]
  rolePermissions           RolePermission[]
  workflowRules             RoleWorkflowRule[]
  workflowReviewAssignments RoleWorkflowReviewAssignment[] @relation("WorkflowReviewerRole")
  organigrammDepartment     OrganigrammDepartment?         @relation(fields: [organigrammDepartmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([name])
  @@index([canAccessVereinsleitung])
  @@index([canAttendVereinsleitungMeetings])
  @@index([organigrammDepartmentId])
  @@index([organigrammSortOrder])
  @@index([organigrammIsGroupRole])
}

model Permission {
  id        String           @id @default(cuid())
  key       String           @unique
  name      String
  module    PermissionModule
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model RoleWorkflowRule {
  id                 String         @id @default(cuid())
  roleId             String
  domain             WorkflowDomain
  action             WorkflowAction
  requiresReview     Boolean        @default(true)
  allowsDirectManage Boolean        @default(false)
  allowsReview       Boolean        @default(false)
  allowsApprove      Boolean        @default(false)
  allowsPublish      Boolean        @default(false)
  allowsSeriesReview Boolean        @default(false)
  isActive           Boolean        @default(true)
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  role              Role                           @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewAssignments RoleWorkflowReviewAssignment[]

  @@unique([roleId, domain, action])
  @@index([domain, action])
  @@index([isActive])
}

model RoleWorkflowReviewAssignment {
  id             String   @id @default(cuid())
  workflowRuleId String
  reviewerRoleId String
  isRequired     Boolean  @default(true)
  sortOrder      Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workflowRule RoleWorkflowRule @relation(fields: [workflowRuleId], references: [id], onDelete: Cascade, onUpdate: Cascade, map: "RoleWorkflowReviewAssignment_workflowRuleId_fkey")
  reviewerRole Role             @relation("WorkflowReviewerRole", fields: [reviewerRoleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([workflowRuleId, reviewerRoleId])
  @@index([reviewerRoleId])
  @@index([sortOrder])
}

model Season {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamSeasons     TeamSeason[]
  events          Event[]
  eventImportRuns EventImportRun[]

  @@index([isActive])
}

model Person {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  displayName String?
  email       String?
  phone       String?
  dateOfBirth DateTime?
  notes       String?
  isActive    Boolean   @default(true)
  isPlayer    Boolean   @default(false)
  isTrainer   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user                        User?
  playerSquadMembers          PlayerSquadMember[]
  trainerTeamMembers          TrainerTeamMember[]
  trainerQualifications       TrainerQualification[]
  vereinsleitungOwnedMatters  VereinsleitungMatter[]
  meetingParticipants         VereinsleitungMeetingParticipant[]
  responsibleMeetingDecisions VereinsleitungMeetingDecision[]
  ownedInitiatives            VereinsleitungInitiative[]
  assignedInitiativeWorkItems VereinsleitungInitiativeWorkItem[]

  @@index([lastName, firstName])
  @@index([email])
  @@index([isActive])
  @@index([isPlayer])
  @@index([isTrainer])
}


model TrainerQualification {
  id               String                     @id @default(cuid())
  personId         String
  type             TrainerQualificationType   @default(DIPLOMA)
  status           TrainerQualificationStatus @default(UNKNOWN)
  title            String
  issuer           String?
  licenseNumber    String?
  issuedAt         DateTime?
  expiresAt        DateTime?
  documentUrl      String?
  remarks          String?
  isClubVerified   Boolean                    @default(false)
  isWebsiteVisible Boolean                    @default(false)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([personId])
  @@index([type])
  @@index([status])
  @@index([expiresAt])
  @@index([isClubVerified])
}
model Team {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  category         TeamCategory
  genderGroup      String?
  ageGroup         String?
  sortOrder        Int          @default(0)
  isActive         Boolean      @default(true)
  websiteVisible   Boolean      @default(true)
  infoboardVisible Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  teamSeasons     TeamSeason[]
  events          Event[]
  eventImportRuns EventImportRun[]

  @@index([category, sortOrder])
  @@index([isActive])
}

model TeamSeason {
  id                        String           @id @default(cuid())
  teamId                    String
  seasonId                  String
  displayName               String
  shortName                 String?
  status                    TeamSeasonStatus @default(ACTIVE)
  websiteVisible            Boolean          @default(true)
  infoboardVisible          Boolean          @default(true)
  squadWebsiteVisible       Boolean          @default(true)
  trainerTeamWebsiteVisible Boolean          @default(true)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  team               Team                @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  season             Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  playerSquadMembers PlayerSquadMember[]
  trainerTeamMembers TrainerTeamMember[]

  @@unique([teamId, seasonId])
  @@index([seasonId])
  @@index([status])
  @@index([squadWebsiteVisible])
  @@index([trainerTeamWebsiteVisible])
}

model PlayerSquadMember {
  id               String            @id @default(cuid())
  teamSeasonId     String
  personId         String
  status           PlayerSquadStatus @default(ACTIVE)
  shirtNumber      Int?
  positionLabel    String?
  isCaptain        Boolean           @default(false)
  isViceCaptain    Boolean           @default(false)
  isWebsiteVisible Boolean           @default(true)
  sortOrder        Int               @default(0)
  remarks          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  teamSeason TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  person     Person     @relation(fields: [personId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([teamSeasonId, personId])
  @@index([personId])
  @@index([teamSeasonId, status])
  @@index([teamSeasonId, isWebsiteVisible])
  @@index([teamSeasonId, sortOrder])
}

model TrainerTeamMember {
  id               String            @id @default(cuid())
  teamSeasonId     String
  personId         String
  status           TrainerTeamStatus @default(ACTIVE)
  roleLabel        String?
  isWebsiteVisible Boolean           @default(true)
  sortOrder        Int               @default(0)
  remarks          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  teamSeason TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  person     Person     @relation(fields: [personId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([teamSeasonId, personId])
  @@index([personId])
  @@index([teamSeasonId, status])
  @@index([teamSeasonId, isWebsiteVisible])
  @@index([teamSeasonId, sortOrder])
}

model Event {
  id       String      @id @default(cuid())
  seasonId String
  teamId   String?
  type     EventType
  source   EventSource
  status   EventStatus @default(SCHEDULED)

  reviewStage       ReviewWorkflowStage @default(DRAFT)
  reviewRequestedAt DateTime?
  reviewedAt        DateTime?
  publishedAt       DateTime?
  reviewNotes       String?
  createdByUserId   String?
  reviewedByUserId  String?
  approvedByUserId  String?
  rejectedByUserId  String?
  publishedByUserId String?

  title       String
  description String?
  location    String?

  startAt DateTime
  endAt   DateTime?

  externalSource   String?
  externalSourceId String?
  importBatchKey   String?
  lastSyncedAt     DateTime?

  opponentName     String?
  organizerName    String?
  competitionLabel String?
  homeAway         String?
  resultLabel      String?
  meetingTime      DateTime?

  websiteVisible       Boolean @default(true)
  infoboardVisible     Boolean @default(false)
  homepageVisible      Boolean @default(false)
  wochenplanVisible    Boolean @default(false)
  trainingsplanVisible Boolean @default(false)
  teamPageVisible      Boolean @default(false)

  sortOrder Int     @default(0)
  remarks   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season              Season                    @relation(fields: [seasonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  team                Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  planningAllocations EventPlanningAllocation[]

  @@index([seasonId, type])
  @@index([teamId, type])
  @@index([startAt])
  @@index([status])
  @@index([source])
  @@index([reviewStage])
  @@index([reviewRequestedAt])
  @@index([publishedAt])
  @@index([websiteVisible])
  @@index([infoboardVisible])
  @@index([wochenplanVisible])
  @@index([trainingsplanVisible])
  @@index([teamPageVisible])
  @@index([externalSource, externalSourceId])
  @@index([importBatchKey])
}

model PlanningResource {
  id        String               @id @default(cuid())
  key       String               @unique
  name      String
  type      PlanningResourceType
  sortOrder Int                  @default(0)
  isActive  Boolean              @default(true)
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  allocations EventPlanningAllocation[]

  @@index([type, sortOrder])
  @@index([isActive])
}

model EventPlanningAllocation {
  id         String                 @id @default(cuid())
  eventId    String
  resourceId String
  mode       PlanningAllocationMode @default(FLEXIBLE)
  startsAt   DateTime?
  endsAt     DateTime?
  label      String?
  notes      String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  event    Event            @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  resource PlanningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([eventId, resourceId])
  @@index([eventId])
  @@index([resourceId])
  @@index([mode])
  @@index([startsAt])
  @@index([endsAt])
}

model EventImportRun {
  id       String               @id @default(cuid())
  source   EventSource
  status   EventImportRunStatus @default(PENDING)
  type     EventType?
  seasonId String?
  teamId   String?

  importBatchKey String    @unique
  fileName       String?
  startedAt      DateTime?
  finishedAt     DateTime?

  rowsDetected Int @default(0)
  rowsCreated  Int @default(0)
  rowsUpdated  Int @default(0)
  rowsSkipped  Int @default(0)
  rowsFailed   Int @default(0)

  summary      String?
  errorMessage String?
  metadataJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([source, status])
  @@index([type])
  @@index([seasonId])
  @@index([teamId])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  moduleKey    String
  entityType   String
  entityId     String
  action       String
  beforeJson   Json?
  afterJson    Json?
  metadataJson Json?
  createdAt    DateTime @default(now())

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([moduleKey])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model VereinsleitungMatter {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("OPEN")
  priority      String    @default("MEDIUM")
  ownerPersonId String?
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner        Person?                       @relation(fields: [ownerPersonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  meetingLinks VereinsleitungMeetingMatter[]

  @@index([status])
  @@index([priority])
  @@index([ownerPersonId])
  @@index([dueDate])
}

model VereinsleitungMeeting {
  id                        String                              @id @default(cuid())
  title                     String
  slug                      String                              @unique
  subtitle                  String?
  description               String?
  status                    String                              @default("PLANNED")
  approvalStatus            VereinsleitungMeetingApprovalStatus @default(DRAFT)
  approvalSubmittedAt       DateTime?
  approvedAt                DateTime?
  rejectedAt                DateTime?
  approvalNotes             String?
  approvalRequestedByUserId String?
  approvedByUserId          String?
  rejectedByUserId          String?
  location                  String?
  onlineMeetingUrl          String?
  meetingMode               VereinsleitungMeetingMode           @default(ON_SITE)
  meetingProvider           VereinsleitungMeetingProvider       @default(NONE)
  externalMeetingUrl        String?
  teamsJoinUrl              String?
  teamsMeetingId            String?
  teamsCalendarEventId      String?
  teamsSyncStatus           VereinsleitungTeamsSyncStatus       @default(NOT_CONFIGURED)
  teamsLastSyncedAt         DateTime?
  teamsErrorMessage         String?
  teamsOrganizerUserId      String?
  startAt                   DateTime
  endAt                     DateTime?
  notes                     String?
  carryOverSourceMeetingId  String?
  createdAt                 DateTime                            @default(now())
  updatedAt                 DateTime                            @updatedAt

  carryOverSourceMeeting  VereinsleitungMeeting?               @relation("VereinsleitungMeetingCarryOver", fields: [carryOverSourceMeetingId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  carryOverTargetMeetings VereinsleitungMeeting[]              @relation("VereinsleitungMeetingCarryOver")
  matterLinks             VereinsleitungMeetingMatter[]
  carriedOverMatterLinks  VereinsleitungMeetingMatter[]        @relation("VereinsleitungMeetingMatterCarryOver")
  participants            VereinsleitungMeetingParticipant[]
  agendaItems             VereinsleitungMeetingAgendaItem[]
  decisions               VereinsleitungMeetingDecision[]
  protocolEntries         VereinsleitungMeetingProtocolEntry[]
  sourcedWorkItems        VereinsleitungInitiativeWorkItem[]   @relation("InitiativeWorkItemSourceMeeting")

  @@index([startAt])
  @@index([status])
  @@index([approvalStatus])
  @@index([approvalSubmittedAt])
  @@index([approvedAt])
  @@index([rejectedAt])
  @@index([meetingMode])
  @@index([meetingProvider])
  @@index([teamsSyncStatus])
  @@index([teamsOrganizerUserId])
  @@index([carryOverSourceMeetingId])
}

model VereinsleitungMeetingMatter {
  id                       String   @id @default(cuid())
  meetingId                String
  matterId                 String
  sortOrder                Int      @default(0)
  carriedOverFromMeetingId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  meeting                VereinsleitungMeeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  matter                 VereinsleitungMatter   @relation(fields: [matterId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  carriedOverFromMeeting VereinsleitungMeeting? @relation("VereinsleitungMeetingMatterCarryOver", fields: [carriedOverFromMeetingId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([meetingId, matterId])
  @@index([matterId])
  @@index([sortOrder])
  @@index([carriedOverFromMeetingId])
}

model VereinsleitungMeetingParticipant {
  id          String                                 @id @default(cuid())
  meetingId   String
  personId    String?
  displayName String
  roleLabel   String?
  status      VereinsleitungMeetingParticipantStatus @default(INVITED)
  sortOrder   Int                                    @default(0)
  remarks     String?
  createdAt   DateTime                               @default(now())
  updatedAt   DateTime                               @updatedAt

  meeting VereinsleitungMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  person  Person?               @relation(fields: [personId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([meetingId, sortOrder])
  @@index([personId])
  @@index([status])
}

model VereinsleitungMeetingDecision {
  id                     String                            @id @default(cuid())
  meetingId              String
  agendaItemId           String?
  agendaItemTitle        String?
  decisionText           String
  decisionType           VereinsleitungMeetingDecisionType @default(DECISION)
  responsiblePersonId    String?
  responsibleDisplayName String?
  dueDate                DateTime?
  createMatter           Boolean                           @default(false)
  initiativeId           String?
  createInitiative       Boolean                           @default(false)
  initiativeTitle        String?
  sortOrder              Int                               @default(0)
  remarks                String?
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt

  meeting           VereinsleitungMeeting              @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  responsiblePerson Person?                            @relation(fields: [responsiblePersonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  initiative        VereinsleitungInitiative?          @relation(fields: [initiativeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sourcedWorkItems  VereinsleitungInitiativeWorkItem[] @relation("InitiativeWorkItemSourceDecision")

  @@index([meetingId, sortOrder])
  @@index([agendaItemId])
  @@index([decisionType])
  @@index([responsiblePersonId])
  @@index([dueDate])
  @@index([createMatter])
  @@index([initiativeId])
  @@index([createInitiative])
}

model VereinsleitungMeetingProtocolEntry {
  id              String   @id @default(cuid())
  meetingId       String
  agendaItemId    String?
  agendaItemTitle String?
  notes           String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meeting VereinsleitungMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([meetingId, sortOrder])
  @@index([agendaItemId])
}

model VereinsleitungMeetingAgendaItem {
  id          String   @id @default(cuid())
  meetingId   String
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting VereinsleitungMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([meetingId, sortOrder])
}

model VereinsleitungInitiative {
  id             String                         @id @default(cuid())
  title          String
  slug           String                         @unique
  subtitle       String?
  description    String?
  status         VereinsleitungInitiativeStatus @default(IN_PROGRESS)
  ownerPersonId  String?
  ownerRoleLabel String?
  startDate      DateTime?
  targetDate     DateTime?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  owner            Person?                            @relation(fields: [ownerPersonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  workItems        VereinsleitungInitiativeWorkItem[]
  meetingDecisions VereinsleitungMeetingDecision[]

  @@index([status])
  @@index([ownerPersonId])
  @@index([startDate])
  @@index([targetDate])
}

model VereinsleitungInitiativeWorkItem {
  id                    String                                       @id @default(cuid())
  initiativeId          String
  title                 String
  priority              String                                       @default("MAJOR")
  dueDate               DateTime?
  assigneeMode          VereinsleitungInitiativeWorkItemAssigneeMode @default(NONE)
  assigneePersonId      String?
  externalAssigneeLabel String?
  status                VereinsleitungInitiativeWorkItemStatus       @default(BACKLOG)
  sortOrder             Int                                          @default(0)
  sourceMeetingId       String?
  sourceDecisionId      String?
  sourceAgendaItemTitle String?
  createdAt             DateTime                                     @default(now())
  updatedAt             DateTime                                     @updatedAt

  initiative     VereinsleitungInitiative       @relation(fields: [initiativeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  assigneePerson Person?                        @relation(fields: [assigneePersonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sourceMeeting  VereinsleitungMeeting?         @relation("InitiativeWorkItemSourceMeeting", fields: [sourceMeetingId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sourceDecision VereinsleitungMeetingDecision? @relation("InitiativeWorkItemSourceDecision", fields: [sourceDecisionId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([initiativeId, sortOrder])
  @@index([assigneePersonId])
  @@index([status])
  @@index([assigneeMode])
  @@index([dueDate])
  @@index([sourceMeetingId])
  @@index([sourceDecisionId])
}

enum BusinessClubSponsorTier {
  MAIN
  GOLD
  SILVER
  BRONZE
  PARTNER
}

model BusinessClubSponsor {
  id                  String                  @id @default(cuid())
  displayName         String
  companyName         String?
  tier                BusinessClubSponsorTier @default(PARTNER)
  logoUrl             String?
  websiteUrl          String?
  active              Boolean                 @default(true)
  infoboardVisible    Boolean                 @default(false)
  infoboardWeight     Int                     @default(1)
  infoboardSortOrder  Int                     @default(0)
  remarks             String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([active])
  @@index([infoboardVisible])
  @@index([tier])
  @@index([infoboardSortOrder])
}

model WorkflowPolicy {
  id                 String   @id @default(cuid())
  domain             String   // JAHRESPLAN | WOCHENPLAN | TAGESPLAN
  editorRoleKeys     String[] // roles allowed to edit
  reviewerRoleKeys   String[] // roles allowed to review/publish
  targetGroups       String[] // G,F,E,D,C,B,A,AKTIVE,FRAUEN etc
  requireReview      Boolean  @default(true)
  allowSelfApproval  Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([domain])
  @@index([active])
}


