function getSpotlightIcon(type: SpotlightResult["type"]) {
  switch (type) {
    case "person":
      return Users;
    case "team":
      return Shield;
    case "meeting":
      return CalendarDays;
    case "initiative":
      return Flag;
    default:
      return Search;
  }
}

