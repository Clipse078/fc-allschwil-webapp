function formatDateFromDateTimeLocal(value?: string | null) {
  if (!value) {
    return "";
  }

  return value.slice(0, 10);
}

function formatTimeFromDateTimeLocal(value?: string | null) {
  if (!value) {
    return "";
  }

  return value.slice(11, 16);
}

function buildDateTimeLocalValue(date: string, time: string) {
  if (!date) {
    return "";
  }

  return `${date}T${time || "00:00"}`;
}

function getProviderAppUrl(provider: ProviderUiOption, meetingLink: string) {
  const safeLink = meetingLink.trim();

  switch (provider) {
    case "MICROSOFT_TEAMS":
      return safeLink || "msteams:";
    case "SKYPE":
      return safeLink || "skype:";
    case "ZOOM":
      return safeLink || "zoommtg:";
    case "GOOGLE_MEET":
      return safeLink || "";
    default:
