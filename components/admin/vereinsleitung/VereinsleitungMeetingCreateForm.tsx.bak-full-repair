  );

  const filteredOptions = useMemo(() => {
    const safeQuery = query.trim().toLowerCase();

    if (!safeQuery) {
      return initiativeOptions.slice(0, 8);
    }

    return initiativeOptions
      .filter((initiative) => {
        const title = initiative.title.toLowerCase();
        const statusLabel = (initiative.statusLabel ?? initiative.status ?? "").toLowerCase();

        return title.includes(safeQuery) || statusLabel.includes(safeQuery);
      })
      .slice(0, 8);
  }, [query, initiativeOptions]);

  useEffect(() => {
    function handleClickOutside(event: MouseEvent) {
      if (!wrapperRef.current) {
        return;
      }

      if (!wrapperRef.current.contains(event.target as Node)) {
        setIsOpen(false);
      }
    }

    document.addEventListener("mousedown", handleClickOutside);
    return () => document.removeEventListener("mousedown", handleClickOutside);
  }, []);

  return (
    <div ref={wrapperRef} className="relative">
      <div className="flex items-center gap-2 rounded-[16px] border border-slate-200 bg-white px-3 py-2.5 shadow-[0_1px_2px_rgba(15,23,42,0.02)] transition focus-within:border-[#0b4aa2] focus-within:ring-2 focus-within:ring-[#0b4aa2]/15">
        <Search className="h-4 w-4 shrink-0 text-[#0b4aa2]" />
        <input
          value={selectedInitiative ? selectedInitiative.title : query}
          onChange={(event) => {
            setQuery(event.target.value);
            if (selectedInitiativeId) {
              onChange("");
            }
            setIsOpen(true);
          }}
          onFocus={() => setIsOpen(true)}
          placeholder="Initiative suchen"
          className="w-full bg-transparent text-sm text-slate-900 outline-none"
        />
        {selectedInitiativeId ? (
          <button
            type="button"
            onClick={() => {
              onChange("");
              setQuery("");
              setIsOpen(false);
            }}
            className="inline-flex h-6 w-6 items-center justify-center rounded-full text-slate-400 transition hover:bg-slate-100 hover:text-slate-700"
            aria-label="Initiative entfernen"
          >
            <X className="h-3.5 w-3.5" />
          </button>
        ) : null}
      </div>

      {isOpen ? (
        <div className="absolute left-0 top-full z-30 mt-2 w-full overflow-hidden rounded-[20px] border border-slate-200 bg-white shadow-[0_18px_40px_rgba(15,23,42,0.12)]">
          {filteredOptions.length === 0 ? (
            <div className="px-4 py-3 text-sm text-slate-500">
              Keine Initiative gefunden.
            </div>
          ) : (
            <div className="max-h-[280px] overflow-y-auto p-2">
              {filteredOptions.map((initiative) => (
                <div
                  key={initiative.id}
                  className={`flex items-center gap-2 rounded-[14px] px-3 py-2.5 transition ${
                    selectedInitiativeId === initiative.id
                      ? "border border-[#0b4aa2]/15 bg-[#0b4aa2]/[0.05]"
                      : "hover:bg-slate-50"
                  }`}
                >
                  <button
                    type="button"
                    onClick={() => {
                      onChange(initiative.id);
                      setQuery("");
                      setIsOpen(false);
                    }}
                    className="flex min-w-0 flex-1 items-center justify-between gap-3 text-left"
                  >
                    <div className="min-w-0">
                      <div className="flex flex-wrap items-center gap-2">
                        <div className="truncate text-sm font-semibold text-slate-900">
                          {initiative.title}
                        </div>
                        {selectedInitiativeId === initiative.id ? (
                          <span className="inline-flex items-center rounded-full border border-[#0b4aa2]/20 bg-[#0b4aa2]/10 px-2 py-0.5 text-[10px] font-semibold text-[#0b4aa2]">
                            Verknüpft
                          </span>
                        ) : null}
                      </div>
                      <div className="mt-1 flex flex-wrap items-center gap-2">
                        <span
                          className={`inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold ${getInitiativeStatusClass(
                            initiative.status,
                          )}`}
                        >
                          {initiative.statusLabel ?? initiative.status ?? "In Arbeit"}
                        </span>

                        {typeof initiative.progressPercent === "number" ? (
                          <span
                            className={`inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold ${getInitiativeProgressTone(
                              initiative.progressPercent,
                            )}`}
                          >
                            {initiative.progressPercent}%
                          </span>
                        ) : null}
                      </div>
                    </div>

                    <Target className="h-4 w-4 shrink-0 text-[#0b4aa2]" />
                  </button>

                  <Link
                    href={`/vereinsleitung/initiativen/${initiative.slug}`}
                    target="_blank"
                    rel="noreferrer"
                    onClick={(event) => event.stopPropagation()}
                    className="inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition hover:border-[#0b4aa2]/20 hover:text-[#0b4aa2]"
                    title="Initiative öffnen"
                  >
                    <ExternalLink className="h-3.5 w-3.5" />
                  </Link>
                </div>
              ))}
            </div>
          )}
        </div>
      ) : null}
    </div>
  );
}

export default function VereinsleitungMeetingCreateForm({
  matterOptions,
  initiativeOptions = [],
  mode = "create",
  submitLabel = "Meeting erstellen",
  submittingLabel = "Meeting wird erstellt...",
  cancelHref = "/vereinsleitung/meetings",
  initialValues,
  initialSelectedMatterIds,
  initialParticipants,
  initialAgendaItems,
  meetingId,
}: VereinsleitungMeetingCreateFormProps) {
  const router = useRouter();

  const [form, setForm] = useState<FormState>({
    ...INITIAL_STATE,
    ...initialValues,
    meetingProvider: normalizeMeetingProvider(initialValues?.meetingProvider),
    providerUi: inferProviderUi(
      initialValues?.meetingProvider,
      initialValues?.externalMeetingUrl,
      initialValues?.onlineMeetingUrl,
      initialValues?.teamsJoinUrl,
    ),
    teamsSyncStatus: normalizeTeamsSyncStatus(initialValues?.teamsSyncStatus),
    meetingMode:
      inferProviderUi(
        initialValues?.meetingProvider,
        initialValues?.externalMeetingUrl,
        initialValues?.onlineMeetingUrl,
        initialValues?.teamsJoinUrl,
      ) === "NONE"
        ? "ON_SITE"
        : "ONLINE",
    meetingDate:
      initialValues?.meetingDate ??
      formatDateFromDateTimeLocal(initialValues?.startAt),
    startTime:
      initialValues?.startTime ??
      formatTimeFromDateTimeLocal(initialValues?.startAt),
    endTime:
      initialValues?.endTime ??
      formatTimeFromDateTimeLocal(initialValues?.endAt),
    description: initialValues?.description ?? "",
    title: initialValues?.title ?? "",
    location: initialValues?.location ?? "",
    meetingLink:
      initialValues?.meetingLink ??
      initialValues?.teamsJoinUrl ??
      initialValues?.externalMeetingUrl ??
      initialValues?.onlineMeetingUrl ??
      "",
  });

  const [selectedMatterIds, setSelectedMatterIds] = useState<string[]>(
    initialSelectedMatterIds ?? [],
  );
  const [matterAttachments, setMatterAttachments] = useState<Record<string, LocalAttachment[]>>({});
  const [manualMatters, setManualMatters] = useState<ManualMatterRow[]>([]);
  const [participants, setParticipants] = useState<ParticipantRow[]>(
    initialParticipants && initialParticipants.length > 0
      ? initialParticipants.map((participant) => createParticipantRow(participant))
      : [],
  );
  const [agendaItems, setAgendaItems] = useState<AgendaItemRow[]>(
    initialAgendaItems && initialAgendaItems.length > 0
      ? initialAgendaItems.map((item) => createAgendaItem(item))
      : [createAgendaItem()],
  );
  const [pickerItems, setPickerItems] = useState<PeoplePickerPerson[]>([]);
  const [draggingAgendaKey, setDraggingAgendaKey] = useState<string | null>(null);
  const [draggingMatterKey, setDraggingMatterKey] = useState<string | null>(null);
  const [error, setError] = useState("");
  const [isSubmitting, setIsSubmitting] = useState(false);

  const canSubmit = useMemo(() => {
    return Boolean(form.title.trim() && form.meetingDate.trim() && form.startTime.trim());
  }, [form.title, form.meetingDate, form.startTime]);

  const agendaTotalMinutes = useMemo(() => {
    return agendaItems.reduce((sum, item) => {
      const value = Number(item.durationMinutes || "0");
      return sum + (Number.isFinite(value) ? value : 0);
    }, 0);
  }, [agendaItems]);

  const meetingDurationMinutes = useMemo(() => {
    return getMeetingDurationMinutes(form.startTime, form.endTime);
  }, [form.startTime, form.endTime]);

  const agendaBudgetPercent = useMemo(() => {
    if (meetingDurationMinutes <= 0) {
      return 0;
    }

    return Math.min(Math.round((agendaTotalMinutes / meetingDurationMinutes) * 100), 100);
  }, [agendaTotalMinutes, meetingDurationMinutes]);

  const agendaBudgetTone = useMemo(() => {
    return getAgendaBudgetTone(agendaTotalMinutes, meetingDurationMinutes);
  }, [agendaTotalMinutes, meetingDurationMinutes]);

  const showTeamsFields = form.providerUi === "MICROSOFT_TEAMS";
  const showMeetingLinkField = form.providerUi !== "NONE";
  const providerAppUrl = getProviderAppUrl(form.providerUi, form.meetingLink);

  useEffect(() => {
    setForm((current) => ({
      ...current,
      meetingMode: normalizeMeetingModeFromProviderUi(current.providerUi),
    }));
  }, [form.providerUi]);

  useEffect(() => {
    if (form.providerUi === "NONE") {
      setForm((current) => ({
        ...current,
        meetingProvider: "NONE",
        meetingLink: "",
        teamsSyncStatus: "NOT_CONFIGURED",
      }));
      return;
    }

    if (form.providerUi === "MICROSOFT_TEAMS") {
      setForm((current) => ({
        ...current,
        meetingProvider: "MICROSOFT_TEAMS",
        teamsSyncStatus:
          current.teamsSyncStatus === "NOT_CONFIGURED" ? "PENDING" : current.teamsSyncStatus,
      }));
      return;
    }

    setForm((current) => ({
      ...current,
      meetingProvider: "EXTERNAL",
      teamsSyncStatus: "MANUAL",
    }));
  }, [form.providerUi]);

  useEffect(() => {
    if (pickerItems.length === 0) {
      return;
    }

    setParticipants((current) => {
      const existingIds = new Set(current.map((item) => item.personId).filter(Boolean));

      const additions = pickerItems
        .filter((person) => !existingIds.has(person.id))
        .map((person) => createParticipantRowFromPerson(person));

      if (additions.length === 0) {
        return current;
      }

      return [...current, ...additions];
    });

    setPickerItems([]);
  }, [pickerItems]);

  function updateField<Key extends keyof FormState>(key: Key, value: FormState[Key]) {
    setForm((current) => ({
      ...current,
      [key]: value,
    }));
  }

  function toggleMatter(matterId: string) {
    setSelectedMatterIds((current) =>
      current.includes(matterId)
        ? current.filter((entry) => entry !== matterId)
        : [...current, matterId],
    );
  }

  function updateParticipant(
    key: string,
    updater: (participant: ParticipantRow) => ParticipantRow,
  ) {
    setParticipants((current) =>
      current.map((participant) =>
        participant.key === key ? updater(participant) : participant,
      ),
    );
  }

  function removeParticipant(key: string) {
    setParticipants((current) => current.filter((participant) => participant.key !== key));
  }

  function addAgendaItem(initial?: InitialAgendaItem) {
    setAgendaItems((current) => [...current, createAgendaItem(initial)]);
  }

  function updateAgendaItem(key: string, updater: (item: AgendaItemRow) => AgendaItemRow) {
    setAgendaItems((current) => current.map((item) => (item.key === key ? updater(item) : item)));
  }

  function removeAgendaItem(key: string) {
    setAgendaItems((current) => current.filter((item) => item.key !== key));
  }

  function addAgendaAttachments(key: string, files: FileList | null) {
    if (!files || files.length === 0) {
      return;
    }

    const newAttachments = Array.from(files).map(createAttachment);

    updateAgendaItem(key, (current) => ({
      ...current,
      attachments: [...current.attachments, ...newAttachments],
    }));
  }

  function removeAgendaAttachment(key: string, attachmentKey: string) {
    updateAgendaItem(key, (current) => ({
      ...current,
      attachments: current.attachments.filter((attachment) => attachment.key !== attachmentKey),
    }));
  }

  function handleAgendaDragStart(key: string) {
    setDraggingAgendaKey(key);
  }

  function handleAgendaDrop(targetKey: string) {
    if (!draggingAgendaKey || draggingAgendaKey === targetKey) {
      setDraggingAgendaKey(null);
      return;
    }

    setAgendaItems((current) => {
      const fromIndex = current.findIndex((item) => item.key === draggingAgendaKey);
      const toIndex = current.findIndex((item) => item.key === targetKey);
      return moveItem(current, fromIndex, toIndex);
    });

    setDraggingAgendaKey(null);
  }

  function addMatterAttachments(matterId: string, files: FileList | null) {
    if (!files || files.length === 0) {
      return;
    }

    const newAttachments = Array.from(files).map(createAttachment);

    setMatterAttachments((current) => ({
      ...current,
      [matterId]: [...(current[matterId] ?? []), ...newAttachments],
    }));
  }

  function removeMatterAttachment(matterId: string, attachmentKey: string) {
    setMatterAttachments((current) => ({
      ...current,
      [matterId]: (current[matterId] ?? []).filter((attachment) => attachment.key !== attachmentKey),
    }));
  }

  function addManualMatter() {
    setManualMatters((current) => [...current, createManualMatter()]);
  }

  function updateManualMatter(key: string, updater: (item: ManualMatterRow) => ManualMatterRow) {
    setManualMatters((current) => current.map((item) => (item.key === key ? updater(item) : item)));
  }

  function removeManualMatter(key: string) {
    setManualMatters((current) => current.filter((item) => item.key !== key));
  }

  function addManualMatterAttachments(key: string, files: FileList | null) {
    if (!files || files.length === 0) {
      return;
    }

    const newAttachments = Array.from(files).map(createAttachment);

    updateManualMatter(key, (current) => ({
      ...current,
      attachments: [...current.attachments, ...newAttachments],
    }));
  }

  function removeManualMatterAttachment(key: string, attachmentKey: string) {
    updateManualMatter(key, (current) => ({
      ...current,
      attachments: current.attachments.filter((attachment) => attachment.key !== attachmentKey),
    }));
  }

  function handleMatterDragStart(key: string) {
    setDraggingMatterKey(key);
  }

  function handleMatterDrop(targetKey: string) {
    if (!draggingMatterKey || draggingMatterKey === targetKey) {
      setDraggingMatterKey(null);
      return;
    }

    setManualMatters((current) => {
      const fromIndex = current.findIndex((item) => item.key === draggingMatterKey);
      const toIndex = current.findIndex((item) => item.key === targetKey);
      return moveItem(current, fromIndex, toIndex);
    });

    setDraggingMatterKey(null);
  }

  async function handleSubmit(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();

    if (!canSubmit || isSubmitting) {
      return;
    }

    const normalizedParticipants = participants
      .map((participant) => ({
        personId: participant.personId.trim() || null,
        displayName: participant.displayName.trim(),
        roleLabel: participant.roleLabel.trim() || null,
        status: participant.status,
        remarks: participant.remarks.trim() || null,
      }))
      .filter((participant) => participant.displayName);

    const normalizedAgendaItems = agendaItems
      .map((item, index) => ({
        title: item.title.trim(),
        description:
          [
            `Nr.: ${index + 1}`,
            item.assigneeName ? `Assignee: ${item.assigneeName}` : null,
            item.durationMinutes ? `Dauer: ${item.durationMinutes} Min.` : null,
            item.notes.trim() ? `Notiz: ${item.notes.trim()}` : null,
            item.initiativeId
              ? `Initiative: ${
                  initiativeOptions.find((initiative) => initiative.id === item.initiativeId)?.title ??
                  item.initiativeId
                }`
              : null,
            item.attachments.length > 0
              ? `Beilagen: ${item.attachments.map((attachment) => attachment.name).join(", ")}`
              : null,
          ]
            .filter(Boolean)
            .join(" | ") || null,
      }))
      .filter((item) => item.title);

    const linkedMatterNotes = matterOptions
      .filter((matter) => selectedMatterIds.includes(matter.id))
      .map((matter, index) => {
        const attachments = matterAttachments[matter.id] ?? [];

        return [
          `Verknüpfte Pendenz ${index + 1}: ${matter.title}`,
          matter.ownerName ? `Assignee: ${matter.ownerName}` : null,
          matter.dueDateLabel ? `Fällig: ${matter.dueDateLabel}` : null,
          attachments.length > 0
            ? `Beilagen: ${attachments.map((attachment) => attachment.name).join(", ")}`
            : null,
        ]
          .filter(Boolean)
          .join(" | ");
      })
      .join("\n");

    const manualMatterNotes = manualMatters
      .map((item, index) => {
        if (!item.title.trim()) {
          return null;
        }

        return [
          `Manuelle Pendenz ${index + 1}: ${item.title.trim()}`,
          item.assigneeName ? `Assignee: ${item.assigneeName}` : null,
          item.dueDate ? `Fällig: ${item.dueDate}` : null,
          item.priority ? `Priorität: ${item.priority}` : null,
          item.notes.trim() ? `Notiz: ${item.notes.trim()}` : null,
          item.initiativeId
            ? `Initiative: ${
                initiativeOptions.find((initiative) => initiative.id === item.initiativeId)?.title ??
                item.initiativeId
              }`
            : null,
          item.attachments.length > 0
            ? `Beilagen: ${item.attachments.map((attachment) => attachment.name).join(", ")}`
            : null,
        ]
          .filter(Boolean)
          .join(" | ");
      })
      .filter(Boolean)
      .join("\n");

    setIsSubmitting(true);
    setError("");

    try {
      const endpoint =
        mode === "edit" && meetingId
          ? "/api/vereinsleitung/meetings/" + meetingId
          : "/api/vereinsleitung/meetings";

      const method = mode === "edit" ? "PATCH" : "POST";

      const descriptionParts = [
        form.description.trim() || null,
        linkedMatterNotes ? `\n\n${linkedMatterNotes}` : null,
        manualMatterNotes ? `\n\n${manualMatterNotes}` : null,
      ].filter(Boolean);

      const payload = {
        title: form.title.trim(),
        subtitle: null,
        description: descriptionParts.join("") || null,
        location: form.location.trim() || null,
        onlineMeetingUrl: showMeetingLinkField ? form.meetingLink.trim() || null : null,
        startAt: buildDateTimeLocalValue(form.meetingDate, form.startTime),
        endAt: form.endTime ? buildDateTimeLocalValue(form.meetingDate, form.endTime) : null,
        status: "PLANNED",
        meetingMode: form.meetingMode,
        meetingProvider: form.meetingProvider,
        externalMeetingUrl:
          form.providerUi !== "NONE" && form.providerUi !== "MICROSOFT_TEAMS"
            ? form.meetingLink.trim() || null
            : null,
        teamsJoinUrl: form.providerUi === "MICROSOFT_TEAMS" ? form.meetingLink.trim() || null : null,
        teamsSyncStatus: form.providerUi === "MICROSOFT_TEAMS" ? form.teamsSyncStatus : "NOT_CONFIGURED",
        matterIds: selectedMatterIds,
        participants: normalizedParticipants,
        agendaItems: normalizedAgendaItems,
      };

      const response = await fetch(endpoint, {
        method,
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json();

      if (!response.ok) {
        setError(
          typeof data?.error === "string"
            ? data.error
            : "Meeting konnte nicht gespeichert werden.",
        );
        return;
      }

      router.push("/vereinsleitung/meetings/" + data.slug);
      router.refresh();
    } catch (submitError) {
      setError(
        submitError instanceof Error
          ? "Technischer Fehler: " + submitError.message
          : "Meeting konnte nicht gespeichert werden.",
      );
    } finally {
      setIsSubmitting(false);
    }
  }

  return (
    <form onSubmit={handleSubmit} className="space-y-6">
      <div className="grid gap-6 xl:grid-cols-[minmax(0,1.55fr)_minmax(340px,0.85fr)]">
        <SectionCard
          title="Meeting-Details"
          description="Die wichtigsten Sitzungsdaten in einem klaren, premium aufgebauten Bereich."
          accent="blue"
        >
          <div className="grid gap-5 md:grid-cols-2">
            <div className="md:col-span-2">
              <label className="block text-sm font-semibold text-slate-900">
                Titel *
              </label>
              <input
                value={form.title}
                onChange={(event) => updateField("title", event.target.value)}
                placeholder="z. B. Vereinsleitungssitzung Mai 2026"
                className="mt-2 w-full rounded-[20px] border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-900 shadow-[0_1px_2px_rgba(15,23,42,0.02)] outline-none transition focus:border-[#0b4aa2] focus:ring-4 focus:ring-[#0b4aa2]/10"
              />
            </div>

            <div>
              <label className="flex items-center gap-2 text-sm font-semibold text-slate-900">
                <CalendarDays className="h-4 w-4 text-[#0b4aa2]" />
                Datum *
              </label>
              <input
                type="date"
                value={form.meetingDate}
                onChange={(event) => updateField("meetingDate", event.target.value)}
                className="mt-2 w-full rounded-[20px] border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-900 shadow-[0_1px_2px_rgba(15,23,42,0.02)] outline-none transition focus:border-[#0b4aa2] focus:ring-4 focus:ring-[#0b4aa2]/10"
              />
            </div>

            <div>
              <label className="flex items-center gap-2 text-sm font-semibold text-slate-900">
                <MapPin className="h-4 w-4 text-[#0b4aa2]" />
                Ort
              </label>
              <input
                value={form.location}
                onChange={(event) => updateField("location", event.target.value)}
                placeholder="z. B. Clubhaus Sitzungszimmer 1"
                className="mt-2 w-full rounded-[20px] border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-900 shadow-[0_1px_2px_rgba(15,23,42,0.02)] outline-none transition focus:border-[#0b4aa2] focus:ring-4 focus:ring-[#0b4aa2]/10"
              />
            </div>

            <div>
              <label className="flex items-center gap-2 text-sm font-semibold text-slate-900">
                <Clock3 className="h-4 w-4 text-[#0b4aa2]" />
                Startzeit *
              </label>
              <input
                type="time"
                value={form.startTime}
                onChange={(event) => updateField("startTime", event.target.value)}
                className="mt-2 w-full rounded-[20px] border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-900 shadow-[0_1px_2px_rgba(15,23,42,0.02)] outline-none transition focus:border-[#0b4aa2] focus:ring-4 focus:ring-[#0b4aa2]/10"
              />
            </div>

            <div>
              <label className="flex items-center gap-2 text-sm font-semibold text-slate-900">
                <Clock3 className="h-4 w-4 text-[#0b4aa2]" />
                Endzeit
              </label>
              <input
                type="time"
                value={form.endTime}
                onChange={(event) => updateField("endTime", event.target.value)}
                className="mt-2 w-full rounded-[20px] border border-slate-200 bg-white px-4 py-3.5 text-sm text-slate-900 shadow-[0_1px_2px_rgba(15,23,42,0.02)] outline-none transition focus:border-[#0b4aa2] focus:ring-4 focus:ring-[#0b4aa2]/10"
              />
            </div>

            <div className="md:col-span-2 rounded-[24px] border border-slate-200 bg-gradient-to-br from-white via-slate-50/50 to-white p-4">
              <label className="flex items-center gap-2 text-sm font-semibold text-slate-900">
                <MonitorSmartphone className="h-4 w-4 text-[#0b4aa2]" />
                Online-Provider
              </label>

              <div className="mt-3 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                <ProviderTile
