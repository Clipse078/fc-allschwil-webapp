            </div>

            <div className="rounded-[26px] border border-slate-200 bg-gradient-to-br from-white to-slate-50 p-5 shadow-[0_12px_28px_rgba(15,23,42,0.05)]">
              <p className="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
                Zugewiesene Karten
              </p>
              <p className="mt-3 text-[2rem] font-semibold tracking-tight text-slate-900">
                {overview.stats.assignedCardsCount}
              </p>
              <p className="mt-2 text-sm text-slate-500">
                Sichtbare Personen aus realen Rollenzuweisungen.
              </p>
            </div>

            <div className="rounded-[26px] border border-slate-200 bg-gradient-to-br from-white to-slate-50 p-5 shadow-[0_12px_28px_rgba(15,23,42,0.05)]">
              <p className="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-400">
                Noch ohne Bereich
              </p>
              <p className="mt-3 text-[2rem] font-semibold tracking-tight text-slate-900">
                {overview.stats.unassignedRoleCount}
              </p>
              <p className="mt-2 text-sm text-slate-500">
                Rollen, die noch keinem Bereich zugeordnet sind.
              </p>
            </div>
          </div>
        </div>
      </section>

      {canManage ? (
        <section className="grid gap-6 xl:grid-cols-2">
          <article className="overflow-hidden rounded-[32px] border border-slate-200/80 bg-white shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
            <div className="h-1.5 w-full bg-gradient-to-r from-[#0b4aa2] via-[#6a5acd] to-[#d62839]" />
            <div className="p-6">
              <div className="flex items-start gap-3">
                <div className="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-[#0b4aa2]">
                  <Plus className="h-5 w-5" />
                </div>
                <div>
                  <p className="text-xs font-semibold uppercase tracking-[0.18em] text-red-600">
                    Struktur
                  </p>
                  <h2 className="mt-2 text-[1.35rem] font-semibold tracking-tight text-slate-900">
                    Bereich erstellen
                  </h2>
                  <p className="mt-2 text-sm leading-6 text-slate-500">
                    Lege einen neuen Organigramm-Bereich an, zum Beispiel Sport, Medien,
                    Sponsoring oder Vereinsleitung.
                  </p>
                </div>
              </div>

              <form onSubmit={handleCreateDepartment} className="mt-6 space-y-4">
                <label className="block space-y-2">
                  <span className="fca-label">Bereichsname</span>
                  <input
                    className="fca-input"
                    value={departmentName}
                    onChange={(event) => setDepartmentName(event.target.value)}
                    placeholder="Zum Beispiel Sponsoring"
                    required
                  />
                </label>

                <label className="block space-y-2">
                  <span className="fca-label">Beschreibung</span>
                  <textarea
                    className="fca-textarea min-h-[110px]"
                    value={departmentDescription}
                    onChange={(event) => setDepartmentDescription(event.target.value)}
                    placeholder="Kurze Beschreibung des Bereichs"
                  />
                </label>

                <button
                  type="submit"
                  disabled={departmentSubmitting}
                  className="fca-button-primary"
                >
                  {departmentSubmitting ? "Bereich wird erstellt..." : "Bereich erstellen"}
                </button>
              </form>
            </div>
          </article>

          <article className="overflow-hidden rounded-[32px] border border-slate-200/80 bg-white shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
            <div className="h-1.5 w-full bg-gradient-to-r from-[#0b4aa2] via-[#6a5acd] to-[#d62839]" />
            <div className="p-6">
              <div className="flex items-start gap-3">
                <div className="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-[#0b4aa2]">
                  <Users className="h-5 w-5" />
                </div>
                <div>
                  <p className="text-xs font-semibold uppercase tracking-[0.18em] text-red-600">
                    Rollen
                  </p>
                  <h2 className="mt-2 text-[1.35rem] font-semibold tracking-tight text-slate-900">
                    Rolle erstellen
                  </h2>
                  <p className="mt-2 text-sm leading-6 text-slate-500">
                    Neue Rollen werden hier dem Organigramm hinzugefügt. Rechte und feinere
                    Workflow-Regeln können später separat im Benutzer-/Rollenbereich gepflegt werden.
                  </p>
                </div>
              </div>

              <form onSubmit={handleCreateRole} className="mt-6 space-y-4">
                <label className="block space-y-2">
                  <span className="fca-label">Bereich</span>
                  <select
                    className="fca-input"
                    value={roleDepartmentId}
                    onChange={(event) => setRoleDepartmentId(event.target.value)}
                    required
                  >
                    <option value="">Bereich auswählen</option>
                    {overview.departments.map((department) => (
                      <option key={department.id} value={department.id}>
                        {department.title}
                      </option>
                    ))}
                  </select>
                </label>

                <label className="block space-y-2">
                  <span className="fca-label">Rollenname</span>
                  <input
                    className="fca-input"
                    value={roleName}
                    onChange={(event) => setRoleName(event.target.value)}
                    placeholder="Zum Beispiel KiFu Koordinator"
                    required
                  />
                </label>

                <label className="block space-y-2">
                  <span className="fca-label">Beschreibung</span>
                  <textarea
                    className="fca-textarea min-h-[110px]"
                    value={roleDescription}
                    onChange={(event) => setRoleDescription(event.target.value)}
                    placeholder="Kurze Beschreibung der Rolle"
                  />
                </label>

                <label className="fca-toggle-row">
                  <span className="text-sm text-slate-700">Mehrpersonen-/Gruppenrolle</span>
                  <input
                    type="checkbox"
                    checked={isGroupRole}
                    onChange={(event) => setIsGroupRole(event.target.checked)}
                    className="fca-toggle-checkbox"
                  />
                </label>

                <button
                  type="submit"
                  disabled={roleSubmitting || !canCreateRole || !hasDepartments}
                  className="fca-button-primary"
                >
                  {roleSubmitting ? "Rolle wird erstellt..." : "Rolle erstellen"}
                </button>
              </form>
            </div>
          </article>
        </section>
      ) : null}

      {error ? <div className="fca-status-box fca-status-box-error">{error}</div> : null}

      {overview.departments.length === 0 ? (
        <section className="rounded-[32px] border border-dashed border-slate-300 bg-white/80 p-8 text-center shadow-[0_18px_40px_rgba(15,23,42,0.04)]">
          <p className="text-sm font-semibold uppercase tracking-[0.18em] text-slate-400">
            Noch kein Aufbau vorhanden
          </p>
          <h2 className="mt-3 text-[1.5rem] font-semibold tracking-tight text-slate-900">
            Es wurden noch keine Organigramm-Bereiche angelegt
          </h2>
          <p className="mt-3 text-sm leading-7 text-slate-500">
            Starte mit dem ersten Bereich und ergänze danach die passenden Rollen direkt auf dieser
            Seite.
          </p>
        </section>
      ) : null}

      <section className="grid gap-6 xl:grid-cols-3">
        {overview.departments.map((department) => (
          <DepartmentCard
            key={department.id}
            department={department}
            canManage={canManage}
            allDepartments={departmentOptions}
            onSaved={() => router.refresh()}
          />
        ))}
      </section>

      {overview.unassignedRoles.length > 0 ? (
        <section className="overflow-hidden rounded-[32px] border border-slate-200/80 bg-white shadow-[0_18px_40px_rgba(15,23,42,0.06)]">
          <div className="h-1.5 w-full bg-gradient-to-r from-slate-500 via-slate-400 to-slate-300" />
          <div className="p-6">
            <p className="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">
              Aufräumen
            </p>
            <h2 className="mt-2 text-[1.45rem] font-semibold tracking-tight text-slate-900">
              Noch nicht zugeordnete Rollen
            </h2>
            <p className="mt-3 text-sm leading-6 text-slate-500">
              Diese Rollen existieren bereits im System, sind aber noch keinem Organigramm-Bereich
              zugewiesen.
            </p>

            <div className="mt-6 grid gap-5 xl:grid-cols-2">
              {overview.unassignedRoles.map((role) => (
                <RoleEditorCard
                  key={role.id}
                  role={role}
                  departments={departmentOptions}
                  canManage={canManage}
                  initialDepartmentId=""
                  onSaved={() => router.refresh()}
                />
              ))}
            </div>
          </div>
        </section>
      ) : null}
    </div>
  );
}
