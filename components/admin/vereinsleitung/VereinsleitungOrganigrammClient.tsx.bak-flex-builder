"use client";

import { useRouter } from "next/navigation";
import { FormEvent, useMemo, useState } from "react";
import {
  Archive,
  Network,
  Pencil,
  Phone,
  Plus,
  ShieldCheck,
  Trash2,
  Users,
} from "lucide-react";
import type {
  OrganigrammDepartmentSection,
  OrganigrammOverview,
  OrganigrammPersonCard,
  OrganigrammRoleNode,
} from "@/lib/vereinsleitung/organigramm";

type VereinsleitungOrganigrammClientProps = {
  overview: OrganigrammOverview;
  canManage: boolean;
};

type RoleEditorState = {
  roleId: string;
  departmentId: string;
  name: string;
  description: string;
  isGroupRole: boolean;
};

function PersonBadge({ person }: { person: OrganigrammPersonCard }) {
